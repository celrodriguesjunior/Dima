@page "/lancamentos/historico"
@using MudBlazor
@inherits Dima.Web.Pages.Transactions.ListTransactionsPage


<MudText Typo="Typo.h3">Lançamentos</MudText>


<MudDataGrid Items="@Transactions" Filterable="false" QuickFilter="FilterTransactions" Hideable="true" ColumnResizeMode="ResizeMode.Column">
	<ToolBarContent>
		<MudText Typo="Typo.h6">Lançamentos</MudText>
		<MudSpacer />
		<MudTextField @bind-Value="SearchTerm" Placeholder="Filtrar..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" IconSize="Size.Medium" Class="mt-0" />
	</ToolBarContent>

	<Columns>
		<PropertyColumn Property="x => x.Title" Title="Lançamento" />
		<TemplateColumn Title="Tipo" Filterable="false">
			<CellTemplate>
				@if (context.Item.Type == ETransactionType.Deposit)
				{
					<MudChip Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">Entrada</MudChip>
				}
				else if (context.Item.Type == ETransactionType.Withdraw)
				{
					<MudChip Color="Color.Error" Variant="Variant.Filled" Size="Size.Small">Saída</MudChip>
				}
			</CellTemplate>
		</TemplateColumn>
		<PropertyColumn Property="x => x.Amount" Format="C" Title="Valor" Sortable="true">
			<FooterTemplate>@context.Items.Sum(e => e.Amount).ToString("C")</FooterTemplate>
		</PropertyColumn>
	</Columns>

</MudDataGrid>