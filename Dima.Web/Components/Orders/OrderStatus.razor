@using MudBlazor
@inherits OrderStatusComponent

@switch (Status)
{
    case EOrderStatus.Canceled:
        <MudChip T="string" Color="Color.Error">CANCELADO</MudChip>
        break;
    case EOrderStatus.Paid:
        <MudChip T="string" Color="Color.Success">PAGO</MudChip>
        break;
    case EOrderStatus.Refunded:
        <MudChip T="string" Color="Color.Info">REEMBOLSADO</MudChip>
        break;
    case EOrderStatus.WaitingPayment:
        <MudChip T="string" Color="Color.Warning">AGUARDANDO PAGAMENTO</MudChip>
        break;

    default:
        <MudChip T="string" Color="Color.Default">NÃO DEFINIDO</MudChip>
        break;
}
