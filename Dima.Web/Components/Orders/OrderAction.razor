@using MudBlazor
@inherits OrderActionComponent


@switch (Order.Status)
{
    case EOrderStatus.Paid:
        <MudButton FullWidth="true" Color="Color.Warning" Variant="Variant.Outlined" OnClick="OnRefoundButtonClickeAsync">
            SOLICITAR ESTORNO
        </MudButton>
        break;
    case EOrderStatus.WaitingPayment:
        <MudButton FullWidth="true" Color="Color.Success" Variant="Variant.Filled" Size="Size.Large" Class="mb-4" OnClick="OnPayButtonClickedAsync">
            PAGAR COM STRIPE
        </MudButton>
        <MudButton FullWidth="true" Color="Color.Error" Variant="Variant.Outlined" Size="Size.Large" Class="mb-4" OnClick="OnCanceledButtonClickeAsync">
            CANCELAR PEDIDO
        </MudButton>
        break;
    default:
        <MudText></MudText>
        break;

}